<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
</head>
<body>
    <div class="container">
        <h1><%= title %></h1>
        <p><%= message %></p>

        <% if(error && error.stack) { %>
            <pre><%= error.stack %></pre>
        <% } %>
    </div>
</body>
</html>