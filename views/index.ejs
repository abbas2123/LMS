<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acadex</title>
  <link rel="stylesheet" href="/css/index.css">
</head>

<body>
  <div class="container">
    <!-- Header -->
    <header>
      <h1>Acadex</h1>
      <button id="openModal">Add Student</button>
    </header>


    <!-- Message alert -->
    <% if (message) { %>
    <div class="alert alert-success">
      <%= message %>
      <span class="close-btn">&times;</span>
    </div>
    <% } %>

    <!-- Search -->
    <div class="filters">
      <div class="search-container">
        <input type="search" name="search" id="search" placeholder="Search by name,email,course,batch">
        <button>Search</button>
      </div>
    </div>

    <!-- Table -->
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Email</th>
            <th>Course</th>
            <th>Batch</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (students && students.length > 0) { %>
            <% students.forEach(student => { %>
              <tr data-id="<%= student._id %>">
                <td><%= student.name %></td>
                <td><%= student.age %></td>
                <td><%= student.email %></td>
                <td><%= student.course %></td>
                <td><%= student.batch %></td>
                <td>
                  <button class="openEditModal">Edit</button>
                  <button class="deleteStudent" data-id="<%= student._id %>">Delete</button>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" style="text-align:center; padding:20px;">No students found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

  <!-- Add Student Modal -->
  <div id="addStudentModal" class="modal">
    <div class="modal-content">
      <span class="close" id="closeModal">&times;</span>
      <h2>Add Student</h2>
      <form action="/add" method="POST">
        <input type="text" name="name" placeholder="Name" />
        <p class="errormessage" id="error1"></p>
        <input type="number" name="age" placeholder="Age"  />
        <p class="errormessage" id="error2"></p>
        <input type="email" name="email" placeholder="Email"  />
        <p class="errormessage" id="error3"></p>
        <input type="text" name="course" placeholder="Course"  />
        <p class="errormessage" id="error4"></p>
        <input type="text" name="batch" placeholder="Batch"  />
        <p class="errormessage" id="error5"></p>
        <button type="submit">Add Student</button>
      </form>
    </div>
  </div>

    <!-- edit Student Modal -->
  <div id="editStudentModal" class="modal">
    <div class="modal-content">
      <span class="close" id="closeeditModal">&times;</span>
      <h2>Edit Student</h2>
      <form id="editStudentForm" method="POST">
        <input type="hidden" id="editStudentId" name="id">
        <input type="hidden" name="_method" value="PUT">

        <input type="text" name="name" placeholder="Name" />
        <p class="errormessage" id="err1"></p>

        <input type="number" name="age" placeholder="Age"  />
        <p class="errormessage" id="err2"></p>

        <input type="email" name="email" placeholder="Email"  />
        <p class="errormessage" id="err3"></p>

        <input type="text" name="course" placeholder="Course"  />
        <p class="errormessage" id="err4"></p>

        <input type="text" name="batch" placeholder="Batch"  />
        <p class="errormessage" id="err5"></p>

        <button type="submit">Update Student</button>
      </form>
    </div>
  </div>

  </div>

<script>
document.addEventListener('DOMContentLoaded', () => {

 
  // Add Student Modal
  
  const openModalBtn = document.getElementById('openModal');
  const addModal = document.getElementById('addStudentModal');
  const closeAddModal = document.getElementById('closeModal');
  const addForm = addModal.querySelector('form');

  openModalBtn.onclick = () => addModal.style.display = 'flex';
  closeAddModal.onclick = () => addModal.style.display = 'none';
  
  // Close modal when clicking outside
  window.addEventListener('click', (e) => {
    if(e.target === addModal) addModal.style.display = 'none';
    if(e.target === editModal) editModal.style.display = 'none';
  });

  // Add form validation
  addForm.addEventListener('submit', e => {
    e.preventDefault();
    const name = addForm.name.value.trim();
    const age = parseInt(addForm.age.value);
    const email = addForm.email.value.trim();
    const course = addForm.course.value.trim();
    const batch = addForm.batch.value.trim();
    let valid = true;
    addForm.querySelectorAll('.errormessage').forEach(el => el.textContent = '');
    
    if(!name){ document.getElementById('error1').textContent='Name required'; valid=false;}
    else if(!/^[a-zA-Z\s]{4,30}$/.test(name)){ document.getElementById('error1').textContent='Name 4-30 chars'; valid=false;}

    if(!age || isNaN(age) || age<18 || age>60){ document.getElementById('error2').textContent='Valid age 18-60'; valid=false;}
    if(!email || !/^[a-zA-Z0-9_+%-]+@[a-zA-Z0-9._]+\.[a-zA-Z]{2,}$/.test(email)){ document.getElementById('error3').textContent='Valid email'; valid=false;}
    if(!course){ document.getElementById('error4').textContent='Course required'; valid=false;}
    if(!batch){ document.getElementById('error5').textContent='Batch required'; valid=false;}

    if(valid) addForm.submit();
  });

 
  // Edit Student Modal
  
  const editModal = document.getElementById('editStudentModal');
  const closeEditModal = document.getElementById('closeeditModal');
  const editForm = document.getElementById('editStudentForm');

  editForm.addEventListener('submit', async e => {
    e.preventDefault();
    const id = editForm.querySelector('#editStudentId').value;
    const name = editForm.name.value.trim();
    const age = parseInt(editForm.age.value);
    const email = editForm.email.value.trim();
    const course = editForm.course.value.trim();
    const batch = editForm.batch.value.trim();

    let valid = true;
    editForm.querySelectorAll('.errormessage').forEach(el => el.textContent = '');

    if(!name){ document.getElementById('err1').textContent='Name required'; valid=false;}
    if(!age || isNaN(age) || age<18 || age>60){ document.getElementById('err2').textContent='Valid age'; valid=false;}
    if(!email){ document.getElementById('err3').textContent='Email required'; valid=false;}
    if(!course){ document.getElementById('err4').textContent='Course required'; valid=false;}
    if(!batch){ document.getElementById('err5').textContent='Batch required'; valid=false;}

    if(!valid) return;

    try {
      const res = await fetch(`/update/${id}`, {
        method:'PUT',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({name, age, email, course, batch})
      });
      if(res.ok){ editModal.style.display='none'; location.reload(); }
      else console.error('Update failed');
    } catch(err){ console.error(err); }
  });

  
  // Event Delegation: Edit/Delete

  const tbody = document.querySelector('table tbody');

  tbody.addEventListener('click', e => {
    const target = e.target;

    // Edit
    if(target.classList.contains('openEditModal')){
      const row = target.closest('tr');
      editForm.name.value = row.children[0].textContent;
      editForm.age.value = row.children[1].textContent;
      editForm.email.value = row.children[2].textContent;
      editForm.course.value = row.children[3].textContent;
      editForm.batch.value = row.children[4].textContent;
      editForm.querySelector('#editStudentId').value = row.dataset.id;
      editModal.style.display = 'flex';
    }

    // Delete
    if(target.classList.contains('deleteStudent')){
      const row = target.closest('tr');
      const studentId = target.dataset.id;
      if(!confirm('Are you sure you want to delete this student?')) return;

      fetch(`/delete/${studentId}`, { method:'DELETE', headers:{'Content-Type':'application/json'} })
      .then(res => res.json())
      .then(data => {
        if(data.success){ alert(data.message); row.remove(); }
        else alert(data.message || 'Delete failed');
      })
      .catch(err => { console.error(err); alert('Something went wrong'); });
    }
  });


  // Success Message Close

  document.addEventListener('click', e => {
    if(e.target.classList.contains('close-btn')){
      const alertBox = e.target.closest('.alert');
      if(alertBox){
        alertBox.style.animation = 'fadeOut 0.5s forwards';
        setTimeout(() => alertBox.remove(), 500);
      }
    }
  });

  // Auto-hide after 4s
  const alertBox = document.querySelector('.alert');
  if(alertBox){
    setTimeout(() => {
      alertBox.style.animation = 'fadeOut 0.5s forwards';
      setTimeout(() => alertBox.remove(), 500);
    }, 4000);
  }


  // Search

  const searchInput = document.getElementById('search');
  const searchBtn = searchInput.nextElementSibling;

  const performSearch = async () => {
    const query = searchInput.value.trim();
    try {
      console.log("Search query:", query);
      const res = await fetch(`/search?query=${encodeURIComponent(query)}`);
      const students = await res.json();

      tbody.innerHTML = '';
      if(students.length === 0){
        tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;">No students found.</td></tr>`;
        return;
      }

      students.forEach(student => {
        tbody.innerHTML += `
          <tr data-id="${student._id}">
            <td>${student.name}</td>
            <td>${student.age}</td>
            <td>${student.email}</td>
            <td>${student.course}</td>
            <td>${student.batch}</td>
            <td>
              <button class="openEditModal">Edit</button>
              <button class="deleteStudent" data-id="${student._id}">Delete</button>
            </td>
          </tr>
        `;
      });
    } catch(err){ console.error(err); }
  };

  searchBtn.addEventListener('click', performSearch);
  searchInput.addEventListener('keypress', e => { if(e.key === 'Enter'){ e.preventDefault(); performSearch(); } });

});
</script>

</body>
</html>
